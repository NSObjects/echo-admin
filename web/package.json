{
  "name": "echo-admin-web",
  "version": "0.1.0",
  "private": true,
  "description": "Management UI for Echo Admin",
  "repository": "git@github.com:NSObjects/echo-admin.git",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "dev": "cross-env UMI_ENV=dev MOCK=none max dev",
    "lint": "npm run biome:lint && npm run tsc",
    "lint-staged": "lint-staged",
    "biome:lint": "biome lint",
    "biome": "biome check --write",
    "prepare": "npx husky && max setup",
    "preview": "max preview --port 8000",
    "preview:build": "max build && max preview --port 8000",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:no-mock": "cross-env MOCK=none max dev",
    "start:pre": "cross-env UMI_ENV=pre MOCK=none max dev",
    "start:test": "cross-env UMI_ENV=test MOCK=none max dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "tsc": "max setup && tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@ant-design/pro-components": "^3.1.12-0",
    "antd": "^6.4.3",
    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@umijs/max": "^4.6.64",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.10.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
