# 进程环境变量配置示例
# 应用只读取真实进程环境变量；不会自动加载 .env 文件。
# Docker Compose 会读取 .env 做本地开发端口和凭据替换。

ECHO_ADMIN_APP_NAME=echo-admin
ECHO_ADMIN_APP_VERSION=dev
ECHO_ADMIN_SYSTEM_PORT=:9322
ECHO_ADMIN_SYSTEM_LEVEL=1

# Docker Compose 本地开发端口
ECHO_ADMIN_API_PORT=9322
ECHO_ADMIN_MYSQL_PORT=3306
ECHO_ADMIN_REDIS_PORT=6379
ECHO_ADMIN_MONGODB_PORT=27017
ECHO_ADMIN_JAEGER_UI_PORT=16686
ECHO_ADMIN_OTLP_GRPC_PORT=4317
ECHO_ADMIN_OTLP_HTTP_PORT=4318

# 日志配置
ECHO_ADMIN_LOG_FORMAT=console
ECHO_ADMIN_LOG_OUTPUT=stdout
ECHO_ADMIN_LOG_CALLER=false

# HTTP middleware 配置
ECHO_ADMIN_HTTP_RECOVERY_DISABLED=false
ECHO_ADMIN_HTTP_REQUEST_CONTEXT_DISABLED=false
ECHO_ADMIN_HTTP_REQUEST_LOG_DISABLED=false
ECHO_ADMIN_HTTP_GZIP_DISABLED=false
ECHO_ADMIN_HTTP_SECURE_COOKIES=false
ECHO_ADMIN_HTTP_CORS_ENABLED=false
# 逗号分隔列表，例如: https://app.example.com,https://admin.example.com
ECHO_ADMIN_HTTP_CORS_ALLOW_ORIGINS=
ECHO_ADMIN_HTTP_CORS_ALLOW_METHODS=
ECHO_ADMIN_HTTP_CORS_ALLOW_HEADERS=
ECHO_ADMIN_HTTP_CORS_ALLOW_CREDENTIALS=false
ECHO_ADMIN_HTTP_CORS_EXPOSE_HEADERS=
ECHO_ADMIN_HTTP_CORS_MAX_AGE_SECONDS=0

# 后台基础配置
ECHO_ADMIN_ADMIN_UPLOAD_DIR=uploads
ECHO_ADMIN_ADMIN_BOOTSTRAP_PASSWORD=

# MySQL 密码。host、port、database、username 等拓扑配置写在 config.toml。
ECHO_ADMIN_MYSQL_PASSWORD=echo_admin_dev_password

# Docker Compose 本地 MySQL 容器初始化配置
ECHO_ADMIN_MYSQL_DATABASE=echo_admin
ECHO_ADMIN_MYSQL_USER=echo_admin
ECHO_ADMIN_MYSQL_ROOT_PASSWORD=echo_admin_dev_root_password

# Redis 配置
ECHO_ADMIN_REDIS_ENABLED=false
ECHO_ADMIN_REDIS_ADDRESS=redis:6379
ECHO_ADMIN_REDIS_USERNAME=
ECHO_ADMIN_REDIS_PASSWORD=
ECHO_ADMIN_REDIS_DB=0

# MongoDB 配置
ECHO_ADMIN_MONGODB_ENABLED=false
ECHO_ADMIN_MONGODB_URI=mongodb://mongodb:27017
ECHO_ADMIN_MONGODB_DATABASE=echo_admin

# Jaeger/OpenTelemetry tracing 配置
ECHO_ADMIN_TRACING_ENABLED=false
ECHO_ADMIN_TRACING_ENDPOINT=jaeger:4317
ECHO_ADMIN_TRACING_PROTOCOL=grpc
ECHO_ADMIN_TRACING_INSECURE=true
ECHO_ADMIN_TRACING_SERVICE_NAME=
