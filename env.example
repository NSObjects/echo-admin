# 进程环境变量配置示例
# 应用只读取真实进程环境变量；不会自动加载 .env 文件。
# Docker Compose 会读取 .env 做本地开发端口和凭据替换。

GO_TEMPLATE_APP_NAME=go-template
GO_TEMPLATE_APP_VERSION=dev
GO_TEMPLATE_SYSTEM_PORT=:9322
GO_TEMPLATE_SYSTEM_LEVEL=1

# Docker Compose 本地开发端口
GO_TEMPLATE_API_PORT=9322
GO_TEMPLATE_MYSQL_PORT=3306
GO_TEMPLATE_REDIS_PORT=6379
GO_TEMPLATE_MONGODB_PORT=27017
GO_TEMPLATE_JAEGER_UI_PORT=16686
GO_TEMPLATE_OTLP_GRPC_PORT=4317
GO_TEMPLATE_OTLP_HTTP_PORT=4318

# 日志配置
GO_TEMPLATE_LOG_FORMAT=console
GO_TEMPLATE_LOG_OUTPUT=stdout
GO_TEMPLATE_LOG_CALLER=false

# HTTP middleware 配置
GO_TEMPLATE_HTTP_RECOVERY_DISABLED=false
GO_TEMPLATE_HTTP_REQUEST_CONTEXT_DISABLED=false
GO_TEMPLATE_HTTP_REQUEST_LOG_DISABLED=false
GO_TEMPLATE_HTTP_GZIP_DISABLED=false
GO_TEMPLATE_HTTP_CORS_ENABLED=false
# 逗号分隔列表，例如: https://app.example.com,https://admin.example.com
GO_TEMPLATE_HTTP_CORS_ALLOW_ORIGINS=
GO_TEMPLATE_HTTP_CORS_ALLOW_METHODS=
GO_TEMPLATE_HTTP_CORS_ALLOW_HEADERS=
GO_TEMPLATE_HTTP_CORS_ALLOW_CREDENTIALS=false
GO_TEMPLATE_HTTP_CORS_EXPOSE_HEADERS=
GO_TEMPLATE_HTTP_CORS_MAX_AGE_SECONDS=0

# JWT 配置
GO_TEMPLATE_JWT_ENABLED=false
GO_TEMPLATE_JWT_SECRET=

# MySQL 配置
# Docker Compose API 容器使用 service hostname；本机运行请改成 127.0.0.1。
GO_TEMPLATE_MYSQL_ENABLED=false
GO_TEMPLATE_MYSQL_DSN=go_template:go_template_dev_password@tcp(mysql:3306)/go_template?charset=utf8mb4&parseTime=true&loc=Local
GO_TEMPLATE_MYSQL_DATABASE=go_template
GO_TEMPLATE_MYSQL_USER=go_template
GO_TEMPLATE_MYSQL_PASSWORD=go_template_dev_password
GO_TEMPLATE_MYSQL_ROOT_PASSWORD=go_template_dev_root_password

# Redis 配置
GO_TEMPLATE_REDIS_ENABLED=false
GO_TEMPLATE_REDIS_ADDRESS=redis:6379
GO_TEMPLATE_REDIS_USERNAME=
GO_TEMPLATE_REDIS_PASSWORD=
GO_TEMPLATE_REDIS_DB=0

# MongoDB 配置
GO_TEMPLATE_MONGODB_ENABLED=false
GO_TEMPLATE_MONGODB_URI=mongodb://mongodb:27017
GO_TEMPLATE_MONGODB_DATABASE=go_template

# Jaeger/OpenTelemetry tracing 配置
GO_TEMPLATE_TRACING_ENABLED=false
GO_TEMPLATE_TRACING_ENDPOINT=jaeger:4317
GO_TEMPLATE_TRACING_PROTOCOL=grpc
GO_TEMPLATE_TRACING_INSECURE=true
GO_TEMPLATE_TRACING_SERVICE_NAME=
